# Server
PORT=4000
NODE_ENV=development

# MongoDB (use MongoDB Atlas or local)
MONGODB_URI=example
appName=resolve

# JWT
JWT_SECRET=token
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=https://resolve-ten.vercel.app

# Email (Brevo — OTP verification)
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=resolveishere@gmail.com
BREVO_FROM_NAME=Resolve
